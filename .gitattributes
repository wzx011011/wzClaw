# Auto detect text files and normalize to LF
* text=auto eol=lf

# Source code
*.ts text
*.tsx text
*.js text
*.jsx text
*.dart text
*.css text
*.html text
*.json text
*.yaml text
*.yml text
*.md text
*.graphql text

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Config files
*.toml text
*.ini text
*.cfg text
.editorconfig text
.gitattributes text
.gitignore text
.env.example text
Dockerfile text
docker-compose*.yml text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.apk binary
*.exe binary
*.msi binary
*.zip binary
*.tar.gz binary

# Generated files
package-lock.json text eol=lf
yarn.lock text eol=lf
