# wzxClaw Relay Server — Environment Variables
# Copy this file to .env and fill in your values

# === Required ===

# Authentication token for desktop ↔ mobile connections
AUTH_TOKEN=your-secret-token-here

# === Server ===

# Port to listen on (default: 8080)
# PORT=8080

# === Optional: Firebase Push Notifications ===

# Firebase service account JSON string (for mobile push notifications)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Or path to service account credentials file
# GOOGLE_APPLICATION_CREDENTIALS=
