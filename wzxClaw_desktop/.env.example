# wzxClaw Desktop — Environment Variables
# Copy this file to .env and fill in your values

# === LLM API Keys ===
# At least one provider key is required for the agent to work

# OpenAI-compatible providers (GPT-4o, DeepSeek, GLM-4 via OpenAI API)
OPENAI_API_KEY=

# Anthropic-compatible providers (Claude, GLM-5 via Anthropic API)
ANTHROPIC_API_KEY=

# === Optional: Custom API Base URLs ===
# Override the default endpoint for each provider
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# === Optional: Observability (Langfuse) ===
# Enable agent session tracing
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=http://localhost:3000

# === Optional: Eval / Benchmark ===
# ANTHROPIC_AUTH_TOKEN=
# BENCHMARK_WORKSPACE_ID=

# === Optional: Plugin & Skill Development ===
# WZXCLAW_MANAGED_PLUGINS_DIR=
# WZXCLAW_MANAGED_SKILLS_DIR=
